rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isParticipant(gameId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerIds;
    }

    function isWaitingGame(gameId) {
      return signedIn()
        && get(/databases/$(database)/documents/games/$(gameId)).data.status == 'waiting';
    }

    match /games/{gameId} {
      allow list: if signedIn() && resource.data.status == 'waiting';
      allow read: if isParticipant(gameId)
        || (signedIn() && resource.data.status == 'waiting');
      allow create: if signedIn() && request.resource.data.hostPlayerId == request.auth.uid;
      allow update: if isParticipant(gameId);

      match /players/{playerId} {
        allow read: if isParticipant(gameId) || isWaitingGame(gameId);
        allow create: if signedIn() && playerId == request.auth.uid;
        allow update: if signedIn() && (playerId == request.auth.uid || isParticipant(gameId));
      }

      match /moves/{moveId} {
        allow read: if isParticipant(gameId);
        allow create: if isParticipant(gameId) && request.auth.uid == request.resource.data.playerId;
      }
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;

      match /history/{matchId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }
  }
}
